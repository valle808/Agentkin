// AgentKin Platform — Prisma Schema (Python/FastAPI)

generator client_py {
  provider = "c:/xampp/htdocs/agentkin/backend-fastapi/venv/Scripts/prisma-client-py.exe"
  interface = "asyncio"
  recursive_type_depth = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  KIN
  DEVELOPER
  ADMIN
}

enum KinTaskStatus {
  OPEN
  CLAIMED
  IN_REVIEW
  COMPLETED
  CANCELLED
  DISPUTED
}

enum TransactionProvider {
  STRIPE
  CRYPTO
  INTERNAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TASK_PAYMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  PROCESSED
  FAILED
}

// ─── User & Profiles ────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  role             Role      @default(KIN)
  stripeCustomerId String?   @unique
  solanaWalletAddress String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  kinProfile   KinProfile?
  agentProfiles AgentProfile[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  transactions     Transaction[]
}

model AgentProfile {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  // Identity
  agentName String?
  modelType String? // e.g. "gpt-4", "claude-3"

  // Auth — autonomous API access
  API_Key String @unique

  // Finance
  balance                Decimal @default(0)
  stripeConnectAccountId String? @unique

  // Reputation
  agentRating    Float    @default(5.0)
  paymentSpeedAvg Float   @default(0.0) // Minutes to verify
  disputeCount   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  kinTasks KinTask[]
}

model KinProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Profile
  skills String[]
  bio    String?
  rating Decimal @default(0)

  // Reputation (New System)
  kinRating      Float    @default(5.0)
  totalTasks     Int      @default(0)
  completionRate Float    @default(1.0) // 0.0 to 1.0
  onTimeRate     Float    @default(1.0)

  // Finance
  stripeConnectAccountId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  applications Application[]
  kinTasks     KinTask[]     @relation("ClaimedTasks")
}

// ─── Tasks ──────────────────────────────────────────────

model KinTask {
  id          String        @id @default(cuid())
  title       String
  description String
  budget      Decimal
  currency    String        @default("USD") // USD, SOL, BTC, ETH, XRP, BNB
  status      KinTaskStatus @default(OPEN)
  proofOfWork String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Agent who posted the task
  agentId String
  agent   AgentProfile @relation(fields: [agentId], references: [id])

  // Kin who claimed the task
  kinId String?
  kin   KinProfile? @relation("ClaimedTasks", fields: [kinId], references: [id])

  // Relations
  applications Application[]
  reviews      Review[]
  transactions Transaction[]
  platformRevenues PlatformRevenue[]
}

// ─── Applications ───────────────────────────────────────

model Application {
  id          String   @id @default(cuid())
  coverLetter String?
  price       Decimal?
  createdAt   DateTime @default(now())

  kinTaskId String
  kinTask   KinTask    @relation(fields: [kinTaskId], references: [id])

  kinId String
  kin   KinProfile @relation(fields: [kinId], references: [id])

  @@unique([kinTaskId, kinId])
}

// ─── Transactions (Stripe ACP) ──────────────────────────

model Transaction {
  id       String            @id @default(cuid())
  amount   Decimal
  type     TransactionType
  provider TransactionProvider @default(INTERNAL)
  currency String              @default("USD")

  // Stripe ACP fields
  stripePaymentIntentId String? @unique
  sharedPaymentTokenId  String?
  externalId            String? // Stripe Intent ID or Crypto Tx Hash
  
  // Multi-Chain Fields
  txHash      String?   @unique
  chain       String?   // SOL, BTC, ETH, XRP, BNB
  fromAddress String?
  toAddress   String?
  memo        String?   // For XRP tags

  // Agent Commerce Protocol (ACP)
  agentSignature String?
  status         TransactionStatus @default(PENDING)
  authorizedAt   DateTime?

  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  kinTaskId String?
  kinTask   KinTask? @relation(fields: [kinTaskId], references: [id])
}

// ─── Reviews ────────────────────────────────────────────

model Review {
  id       String  @id @default(cuid())
  rating   Int     // 1-5
  comment  String?
  authorId String

  kinTaskId String
  kinTask   KinTask @relation(fields: [kinTaskId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Messages ───────────────────────────────────────────

model Message {
  id       String @id @default(cuid())
  content  String
  fromId   String
  toId     String
  userFrom User   @relation("SentMessages", fields: [fromId], references: [id])
  userTo   User   @relation("ReceivedMessages", fields: [toId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Platform Revenue ───────────────────────────────────

model PlatformRevenue {
  id        String   @id @default(cuid())
  amount    Decimal
  source    String   // "TASK_CREATION_FEE" or "TASK_PAYOUT_FEE"
  kinTaskId String
  kinTask   KinTask  @relation(fields: [kinTaskId], references: [id])
  
  createdAt DateTime @default(now())
}
